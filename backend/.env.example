# --- Server ---
PORT=5678
CORS_ORIGINS=https://studio.lsaigc.com,https://drama.lsaigc.com

# --- Auth (leave empty for standalone mode) ---
NEXTAUTH_SECRET=

# --- Gateway (root URL without /v1 — adapters add their own version prefix) ---
# Example: https://api.lsaigc.com (NOT https://api.lsaigc.com/v1)
GATEWAY_URL=

# --- Storage: "local" (default) or "cos" ---
STORAGE_TYPE=local

# --- COS (only needed when STORAGE_TYPE=cos) ---
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_PUBLIC_URL=

# --- Database: "sqlite" (default) or "postgres" ---
DATABASE_TYPE=sqlite
DB_PATH=
STORAGE_PATH=

# --- PostgreSQL (only needed when DATABASE_TYPE=postgres) ---
# Supabase connection string format:
# DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres
DATABASE_URL=
